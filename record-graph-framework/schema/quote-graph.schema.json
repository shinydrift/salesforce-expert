{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/quote-graph.schema.json",
  "title": "Record Graph",
  "description": "Base contract for a graph of related Salesforce records. This file is the canonical shape; the per-object field/picklist constraints under $defs are GENERATED from SObject describe (see DESIGN.md build steps) and should not be hand-edited.",
  "type": "object",
  "required": [
    "nodes"
  ],
  "additionalProperties": false,
  "properties": {
    "clientRequestId": {
      "type": "string",
      "description": "Idempotency key — replays with the same id are de-duplicated."
    },
    "source": {
      "type": "string",
      "description": "Originating system/agent, for audit."
    },
    "templateId": {
      "type": "string",
      "description": "Optional: the template this graph was expanded from."
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "op": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "delete",
        "upsert"
      ]
    },
    "node": {
      "type": "object",
      "required": [
        "alias",
        "objectApiName",
        "op",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "alias": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$",
          "description": "Local id, unique within the graph. Children reference parents by this."
        },
        "objectApiName": {
          "type": "string",
          "description": "SObject API name, e.g. Quote, QuoteLineItem.",
          "enum": [
            "Quote",
            "QuoteLineItem",
            "Opportunity",
            "OpportunityLineItem"
          ]
        },
        "op": {
          "$ref": "#/$defs/op"
        },
        "id": {
          "type": "string",
          "description": "Salesforce record Id — required for update/delete, optional for upsert."
        },
        "parentAlias": {
          "type": "string",
          "description": "alias of the parent node in this graph."
        },
        "parentField": {
          "type": "string",
          "description": "FK field on this object that points at the parent, e.g. QuoteId."
        },
        "fields": {
          "type": "object",
          "description": "Field API name -> value. Allowed keys + picklist values are constrained per-object by the describe-generated sub-schemas under $defs (e.g. quoteFields).",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "enum": [
                  "update",
                  "delete"
                ]
              }
            }
          },
          "then": {
            "required": [
              "id"
            ]
          }
        },
        {
          "if": {
            "required": [
              "parentAlias"
            ],
            "properties": {
              "parentAlias": {
                "type": "string"
              }
            }
          },
          "then": {
            "required": [
              "parentField"
            ]
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "Quote"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "$ref": "#/$defs/quoteFields"
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "Quote"
              },
              "op": {
                "const": "create"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "required": [
                  "Name"
                ]
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "QuoteLineItem"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "$ref": "#/$defs/quoteLineItemFields"
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "QuoteLineItem"
              },
              "op": {
                "const": "create"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "required": [
                  "Quantity"
                ]
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "Opportunity"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "$ref": "#/$defs/opportunityFields"
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "Opportunity"
              },
              "op": {
                "const": "create"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "required": [
                  "CloseDate",
                  "Name",
                  "StageName"
                ]
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "OpportunityLineItem"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "$ref": "#/$defs/opportunityLineItemFields"
              }
            }
          }
        },
        {
          "$comment": "generated:objectApiName-fields",
          "if": {
            "properties": {
              "objectApiName": {
                "const": "OpportunityLineItem"
              },
              "op": {
                "const": "create"
              }
            }
          },
          "then": {
            "properties": {
              "fields": {
                "required": [
                  "Quantity"
                ]
              }
            }
          }
        }
      ]
    },
    "opportunityFields": {
      "type": "object",
      "description": "GENERATED by scripts/build-schema.mjs from SObject describe — do not hand-edit. Run `node scripts/build-schema.mjs` to refresh. Source: describe('Opportunity').",
      "additionalProperties": false,
      "properties": {
        "AccountId": {
          "type": "string",
          "maxLength": 18
        },
        "Amount": {
          "type": "number"
        },
        "CloseDate": {
          "type": "string",
          "format": "date"
        },
        "Description": {
          "type": "string",
          "maxLength": 32000
        },
        "ForecastCategoryName": {
          "type": "string",
          "enum": [
            "Omitted",
            "Pipeline",
            "Best Case",
            "Commit",
            "Closed"
          ]
        },
        "IsPrivate": {
          "type": "boolean"
        },
        "LeadSource": {
          "type": "string",
          "enum": [
            "Web",
            "Phone Inquiry",
            "Partner Referral",
            "Purchased List",
            "Other"
          ]
        },
        "Name": {
          "type": "string",
          "maxLength": 120
        },
        "NextStep": {
          "type": "string",
          "maxLength": 255
        },
        "Pricebook2Id": {
          "type": "string",
          "maxLength": 18
        },
        "Probability": {
          "type": "number"
        },
        "StageName": {
          "type": "string",
          "enum": [
            "Prospecting",
            "Qualification",
            "Needs Analysis",
            "Value Proposition",
            "Id. Decision Makers",
            "Proposal/Price Quote",
            "Negotiation/Review",
            "Closed Won",
            "Closed Lost"
          ]
        },
        "Type": {
          "type": "string",
          "enum": [
            "Existing Customer - Upgrade",
            "Existing Customer - Replacement",
            "Existing Customer - Downgrade",
            "New Customer"
          ]
        }
      }
    },
    "opportunityLineItemFields": {
      "type": "object",
      "description": "GENERATED by scripts/build-schema.mjs from SObject describe — do not hand-edit. Run `node scripts/build-schema.mjs` to refresh. Source: describe('OpportunityLineItem').",
      "additionalProperties": false,
      "properties": {
        "Description": {
          "type": "string",
          "maxLength": 255
        },
        "Discount": {
          "type": "number"
        },
        "OpportunityId": {
          "type": "string",
          "maxLength": 18
        },
        "PricebookEntryId": {
          "type": "string",
          "maxLength": 18
        },
        "Quantity": {
          "type": "number"
        },
        "ServiceDate": {
          "type": "string",
          "format": "date"
        },
        "TotalPrice": {
          "type": "number"
        },
        "UnitPrice": {
          "type": "number"
        }
      }
    },
    "quoteFields": {
      "type": "object",
      "description": "GENERATED by scripts/build-schema.mjs from SObject describe — do not hand-edit. Run `node scripts/build-schema.mjs` to refresh. Source: describe('Quote').",
      "additionalProperties": false,
      "properties": {
        "BillingName": {
          "type": "string",
          "maxLength": 121
        },
        "ContactId": {
          "type": "string",
          "maxLength": 18
        },
        "Description": {
          "type": "string",
          "maxLength": 32000
        },
        "Email": {
          "type": "string",
          "format": "email",
          "maxLength": 121
        },
        "ExpirationDate": {
          "type": "string",
          "format": "date"
        },
        "Name": {
          "type": "string",
          "maxLength": 80
        },
        "OpportunityId": {
          "type": "string",
          "maxLength": 18
        },
        "Phone": {
          "type": "string",
          "maxLength": 40
        },
        "Pricebook2Id": {
          "type": "string",
          "maxLength": 18
        },
        "ShippingHandling": {
          "type": "number"
        },
        "Status": {
          "type": "string",
          "enum": [
            "Draft",
            "Needs Review",
            "In Review",
            "Approved",
            "Rejected",
            "Presented",
            "Accepted",
            "Denied"
          ]
        },
        "Tax": {
          "type": "number"
        }
      }
    },
    "quoteLineItemFields": {
      "type": "object",
      "description": "GENERATED by scripts/build-schema.mjs from SObject describe — do not hand-edit. Run `node scripts/build-schema.mjs` to refresh. Source: describe('QuoteLineItem').",
      "additionalProperties": false,
      "properties": {
        "Description": {
          "type": "string",
          "maxLength": 255
        },
        "Discount": {
          "type": "number"
        },
        "PricebookEntryId": {
          "type": "string",
          "maxLength": 18
        },
        "Quantity": {
          "type": "number"
        },
        "QuoteId": {
          "type": "string",
          "maxLength": 18
        },
        "ServiceDate": {
          "type": "string",
          "format": "date"
        },
        "TotalPrice": {
          "type": "number"
        },
        "UnitPrice": {
          "type": "number"
        }
      }
    }
  },
  "$comment": "GENERATED by scripts/build-schema.mjs from SObject describe — do not hand-edit. Run `node scripts/build-schema.mjs` to refresh."
}
